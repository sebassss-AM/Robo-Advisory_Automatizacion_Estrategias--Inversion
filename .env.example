# Base de datos — Vercel Postgres (Neon)
DATABASE_URL=postgresql://user:password@host:port/db?sslmode=require

# Google Gemini API
GEMINI_API_KEY=tu_api_key_aqui

# Redis — Vercel KV (Upstash)
# Opcional: solo necesario si usas sesiones en Redis
KV_URL=redis://default:password@host:port

# JWT secret para tokens de autenticación
# Opcional: si no se define, usa un valor por defecto (solo para desarrollo)
JWT_SECRET=tu_secreto_jwt_aqui
